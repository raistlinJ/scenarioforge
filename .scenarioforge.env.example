# Shared runtime defaults for Docker Compose and direct Python launches.
#
# Effective precedence:
# 1. Real process environment variables
# 2. .scenarioforge.env (optional local override file)
# 3. .scenarioforge.env.example (committed defaults)
# 4. Built-in Python defaults for any key omitted entirely
#
# Guidance:
# - Treat this file as safe, versioned defaults for the repo.
# - Put machine- or environment-specific overrides in .scenarioforge.env.
# - Most users only need to change CORE_HOST/CORE_PORT and sometimes
#   CORE_SSH_* when pointing at a different CORE daemon.

# CORE gRPC target used by backend operations when no per-run override is provided.
# Use localhost/127.0.0.1 when Flask runs on the same machine as CORE.
# Use an IP or DNS name reachable from the process/container otherwise.
CORE_HOST=12.0.0.100
CORE_PORT=50051

# SSH transport defaults used for remote operations that need shell/file access.
# Usually this is the same host as CORE_HOST; keep them aligned unless your
# environment intentionally separates gRPC and SSH endpoints.
CORE_SSH_HOST=12.0.0.100
CORE_SSH_PORT=22
CORE_SSH_USERNAME=sampleuser
CORE_SSH_PASSWORD=samplepassword

# Flask bind address/port for direct Python launches.
# CORETG_HOST=0.0.0.0 exposes the web UI on all interfaces; use 127.0.0.1
# to keep it local-only.
CORETG_HOST=0.0.0.0
CORETG_PORT=9090

# Runtime mode default for UI behavior:
# - native: standard flow
# - vm: pre-seeds VM-oriented settings and HITL defaults
CORETG_WEBUI_MODE=native

# VM-mode transport values are intentionally shared through CORE_HOST/CORE_PORT
# and CORE_SSH_* above, so native and vm modes use the same endpoint defaults.

# VM-mode HITL defaults.
# These are used to pre-populate participant-network behavior in vm mode.
# Configure one participant-facing CORE VM HITL interface.
# - CORETG_VM_MODE_HITL_CORE_IFX_NAME: expected CORE guest interface name used for RJ-45 HITL (e.g., ens18)
# - CORETG_VM_MODE_HITL_CORE_IFX_ATTACHMENT: attachment type (existing_router, existing_switch, new_router, proxmox_vm)
CORETG_VM_MODE_HITL_ENABLED=true
CORETG_VM_MODE_HITL_CORE_IFX_NAME=ens18
CORETG_VM_MODE_HITL_CORE_IFX_ATTACHMENT=existing_router
CORETG_VM_MODE_HITL_CORE_IFX_DESCRIPTION=Scenario HITL participant network

# Participant UI metadata shown/used in vm-mode HITL flows.
# Use a placeholder URL if no participant UI exists yet.
CORETG_VM_MODE_PARTICIPANT_URL=http://participant-ui.example