# Versioned runtime template.
#
# Effective behavior:
# - Docker Compose and direct Python launches read .scenarioforge.env when present.
# - This file is not loaded automatically at runtime; copy it to .scenarioforge.env
#   to activate or customize these values.
# - When .scenarioforge.env omits a key, built-in Python defaults apply.
# - Real environment variables already present in the process take precedence
#   over values loaded from env files.
#
# Guidance:
# - Treat this file as a safe, versioned template for .scenarioforge.env.
# - Put machine- or environment-specific runtime config in .scenarioforge.env.
# - Most users only need to change CORE_HOST/CORE_PORT and sometimes
#   CORE_SSH_* when pointing at a different CORE daemon.

# CORE gRPC target used by backend operations when no per-run override is provided.
# Set this to the gRPC endpoint reachable from the ScenarioForge process.
# Use localhost/127.0.0.1 when ScenarioForge runs on the CORE host, or when
# an SSH tunnel/port-forward exposes the remote VM's core-daemon locally.
# Use the VM's reachable IP or DNS name when core-daemon listens there directly.
CORE_HOST=127.0.0.1
CORE_PORT=50051

# SSH transport defaults used for remote operations that need shell/file access.
# Set this to the SSH endpoint reachable from ScenarioForge. It is often the
# same host as CORE_HOST, but should be the VM's reachable SSH address when
# CORE_HOST points at a local tunnel such as 127.0.0.1:50051.
CORE_SSH_HOST=12.0.0.100
CORE_SSH_PORT=22
CORE_SSH_USERNAME=sampleuser
CORE_SSH_PASSWORD=samplepassword

# Flask bind address/port for direct Python launches.
# CORETG_HOST=0.0.0.0 exposes the web UI on all interfaces; use 127.0.0.1
# to keep it local-only.
CORETG_HOST=0.0.0.0
CORETG_PORT=9090

# Runtime mode default for UI behavior:
# - native: standard non-VM UI; CORE can still be local, remote, or tunneled
# - vm: pre-seeds VM-oriented settings and VM-only HITL defaults
CORETG_WEBUI_MODE=native

# Shared HITL IPv4 default.
# This IPv4 or CIDR is applied in both native and vm modes when a HITL
# interface entry exists and does not already define an IPv4 value. It does
# not create a HITL interface or enable HITL by itself.
# Leave it blank or remove it in .scenarioforge.env to use deterministic
# auto-allocation instead.
CORETG_HITL_CORE_IFX_IPV4=10.254.200.3/24

# VM-mode transport values are intentionally shared through CORE_HOST/CORE_PORT
# and CORE_SSH_* above, so native and vm modes use the same endpoint defaults.
# In VM mode, CORE_HOST=127.0.0.1 means core-daemon on the remote CORE host
# reached over SSH; Docker bridge startup preserves that value.

# VM-mode HITL defaults.
# These pre-populate participant-network behavior only in vm mode. Configure
# one participant-facing CORE VM interface by Linux interface name, not by
# Proxmox slot id such as net0/net1. The shared HITL IPv4 above only applies
# to this runtime-managed interface when the name is configured.
# - CORETG_VM_MODE_HITL_CORE_IFX_NAME: expected CORE guest interface name used for RJ-45 HITL (e.g., ens19)
# - CORETG_VM_MODE_HITL_CORE_IFX_ATTACHMENT: how that interface connects to the scenario topology (existing_router, existing_switch, new_router, proxmox_vm)
CORETG_VM_MODE_HITL_ENABLED=true
CORETG_VM_MODE_HITL_CORE_IFX_NAME=ens19
CORETG_VM_MODE_HITL_CORE_IFX_ATTACHMENT=existing_router
CORETG_VM_MODE_HITL_CORE_IFX_DESCRIPTION=Scenario HITL participant network

# Flag Sequencing timeouts (seconds), used by the Flow page's browser-side
# request timers so long-running chains don't get reported as a lost
# connection while still in progress.
# - CORETG_FLOW_SEQUENCE_TIMEOUT_S: minimum timeout for the "Sequence" step
#   (/api/flag-sequencing/sequence_preview_plan), which builds/orders the
#   chain. Raise this if sequencing large or highly-constrained chains times
#   out before the backend finishes.
# - CORETG_FLOW_EXECUTE_TIMEOUT_S: upper cap for the "Resolve"/"Execute" step
#   (/api/flag-sequencing/prepare_preview_for_execute), which runs generators.
#   The actual timeout scales with chain length (150s/node + 180s, floor
#   600s) up to this cap. Raise this if resolving long chains or slow
#   (e.g. remote/SSH) generators times out before the backend finishes.
CORETG_FLOW_SEQUENCE_TIMEOUT_S=300
CORETG_FLOW_EXECUTE_TIMEOUT_S=3600

# nginx reverse proxy read timeout (seconds), only used by the Docker Compose
# deployment (nginx/nginx.conf, nginx/nginx-hostweb.conf). Rendered into the
# nginx container at startup by nginx/render-timeouts.sh. Direct Python
# launches (no nginx in front) are unaffected by this value.
# Keep this >= CORETG_FLOW_EXECUTE_TIMEOUT_S so nginx doesn't close the
# Resolve/Execute connection before the browser's own timeout would.
CORETG_NGINX_PROXY_READ_TIMEOUT_S=3700
